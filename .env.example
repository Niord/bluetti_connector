BLUETTI_APP_NAME=BLUETTI Connector
BLUETTI_ENVIRONMENT=development
BLUETTI_SERVER_HOST=127.0.0.1
BLUETTI_SERVER_PORT=8080
BLUETTI_DEV_RELOAD=true

BLUETTI_CLOUD_SSO_URL=https://sso.bluettipower.com
BLUETTI_CLOUD_GATEWAY_URL=https://gw.bluettipower.com
BLUETTI_CLOUD_WSS_URL=wss://gw.bluettipower.com/api/edgeiotgw/ws-coordination/

BLUETTI_USERNAME=
BLUETTI_PASSWORD=
BLUETTI_ACCESS_TOKEN=
BLUETTI_REFRESH_TOKEN=
BLUETTI_TOKEN_STORE_PATH=.local/state/bluetti/tokens.json

BLUETTI_REQUEST_TIMEOUT_SECONDS=15